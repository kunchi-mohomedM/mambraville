<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Brands | Mambraville Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="bg-gray-100">
  <div class="flex h-screen">
    <!-- Mobile Sidebar Toggle -->

    <!-- Sidebar -->
    <%- include('../partials/admin/sidebar') %>


      <!-- Main Content -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Header -->
        <!-- Header -->
        <%- include('../partials/admin/header', { pageTitle: 'Brands' }) %>

          <!-- Content -->
          <div class="flex-1 overflow-y-auto p-4 md:p-6">
            <!-- Page Title and Actions -->
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-6">
              <div>
                <h2 class="text-xl font-semibold text-gray-800">Edit Brand</h2>
                <p class="text-gray-500 mt-1">Update brand details</p>
              </div>
            </div>

            <!-- Form Container -->
            <div class="bg-white p-6 rounded-xl shadow border border-gray-200">
              <form id="brandForm" class="space-y-6" method="POST" action="/admin/editBrands">
                <input type="hidden" name="brandId" value="<%=brands._id%>">

                <!-- Brand Name -->
                <div>
                  <label for="brandname" class="block text-sm font-medium text-gray-700 mb-1">
                    Brand Name
                  </label>
                  <input type="text" id="brandname" name="brandname"
                    class="w-full px-4 py-2.5 bg-gray-50 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition"
                    placeholder="Enter brand name" value="<%=brands.brandname %>">
                  <p id="name-error" class="text-red-500 text-sm mt-1 hidden">Brand name is required</p>
                </div>

                <!-- Description -->
                <div>
                  <label for="description" class="block text-sm font-medium text-gray-700 mb-1">
                    Description
                  </label>
                  <textarea id="description" name="description" rows="4"
                    class="w-full px-4 py-2.5 bg-gray-50 border border-gray-300 rounded-lg text-gray-900 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent transition"
                    placeholder="Enter brand description"><%= brands.description  %></textarea>
                </div>

                <!-- Submit Button -->
                <div class="flex justify-end pt-4">
                  <button type="submit"
                    class="bg-purple-600 text-white px-6 py-2.5 rounded-lg hover:bg-purple-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 transition flex items-center">
                    <i class="fas fa-save mr-2"></i>
                    Save Changes
                  </button>
                </div>
              </form>
            </div>
          </div>
      </div>
  </div>

  <script>

    const form = document.getElementById('brandForm')
    form.addEventListener('submit', async function (e) {
      e.preventDefault(); // Prevent default form submission
      const brandName = document.getElementById('brandname').value.trim();
      const brandDesc = document.getElementById('description').value.trim();
      const nameError = document.getElementById('name-error');

      // Client-side validation
      if (!brandName) {
        nameError.classList.remove('hidden');
        return;
      } else {
        nameError.classList.add('hidden');
      }

      form.submit()

    });

  </script>
</body>

</html>