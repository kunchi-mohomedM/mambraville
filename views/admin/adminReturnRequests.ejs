<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Return Requests | Mambraville Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-100">
  <div class="flex h-screen">
    <!-- Sidebar -->
    <!-- Mobile Sidebar Toggle -->

    <!-- Sidebar -->
    <%- include('../partials/admin/sidebar') %>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Header -->
        <!-- Header -->
        <%- include('../partials/admin/header', { pageTitle: 'Return Requests' }) %>

          <!-- Page Content -->
          <main class="flex-1 overflow-y-auto p-4 md:p-6 bg-white m-2 md:m-4 rounded-lg shadow">
            <!-- Table / Cards -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
              <!-- Desktop Table -->
              <div class="hidden md:block overflow-x-auto">
                <table class="min-w-full">
                  <thead class="bg-gray-100 text-gray-700">
                    <tr>
                      <th class="p-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Order ID</th>
                      <th class="p-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
                      <th class="p-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
                      <th class="p-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Qty</th>
                      <th class="p-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Reason</th>
                      <th class="p-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-200">
                    <% if (returnRequests.length===0) { %>
                      <tr>
                        <td colspan="6" class="p-6 text-center text-gray-500">No return requests found</td>
                      </tr>
                      <% } else { %>
                        <% returnRequests.forEach(r=> { %>
                          <tr class="hover:bg-gray-50 transition">
                            <td class="p-3 whitespace-nowrap text-sm font-medium text-gray-900">
                              <%= r.orderCode %>
                            </td>
                            <td class="p-3 whitespace-nowrap text-sm text-gray-600">
                              <%= r.user.fullname %>
                            </td>
                            <td class="p-3 whitespace-nowrap text-sm text-gray-600">
                              <%= r.item.name %>
                            </td>
                            <td class="p-3 whitespace-nowrap text-sm text-center text-gray-600">
                              <%= r.item.qty %>
                            </td>
                            <td class="p-3 text-sm text-gray-700 max-w-xs truncate" title="<%= r.item.returnReason %>">
                              <%= r.item.returnReason %>
                            </td>
                            <td class="p-3 whitespace-nowrap text-center">
                              <div class="flex justify-center gap-2">
                                <form method="POST"
                                  action="/admin/orders/returns/approve/<%= r.orderId %>/<%= r.item._id %>"
                                  onsubmit="return confirmApprove(event)">
                                  <button
                                    class="flex items-center gap-1 px-3 py-1 bg-green-600 hover:bg-green-700 text-white rounded text-xs transition">
                                    <i class="fas fa-check"></i> Approve
                                  </button>
                                </form>
                                <form method="POST"
                                  action="/admin/orders/returns/reject/<%= r.orderId %>/<%= r.item._id %>"
                                  onsubmit="return confirmCancel(event)">
                                  <button
                                    class="flex items-center gap-1 px-3 py-1 bg-red-600 hover:bg-red-700 text-white rounded text-xs transition">
                                    <i class="fas fa-xmark"></i> Reject
                                  </button>
                                </form>
                              </div>
                            </td>
                          </tr>
                          <% }) %>
                            <% } %>
                  </tbody>
                </table>
              </div>

              <!-- Mobile Cards -->
              <div class="md:hidden grid grid-cols-1 divide-y divide-gray-200">
                <% if (returnRequests.length===0) { %>
                  <div class="p-8 text-center text-gray-500">No return requests found</div>
                  <% } else { %>
                    <% returnRequests.forEach(r=> { %>
                      <div class="p-4 space-y-3">
                        <div class="flex justify-between items-start">
                          <div>
                            <h3 class="text-sm font-bold text-gray-900">#<%= r.orderCode %>
                            </h3>
                            <p class="text-xs text-gray-500">
                              <%= r.user.fullname %>
                            </p>
                          </div>
                          <span class="text-xs bg-yellow-100 text-yellow-800 px-2 py-1 rounded">Pending</span>
                        </div>

                        <div class="border-t border-b py-2 text-sm">
                          <div class="flex justify-between mb-1">
                            <span class="text-gray-500">Product:</span>
                            <span class="font-medium">
                              <%= r.item.name %>
                            </span>
                          </div>
                          <div class="flex justify-between mb-1">
                            <span class="text-gray-500">Qty:</span>
                            <span class="font-medium">
                              <%= r.item.qty %>
                            </span>
                          </div>
                          <div class="flex flex-col mt-1">
                            <span class="text-gray-500 text-xs">Reason:</span>
                            <p class="text-gray-700 italic text-xs">
                              <%= r.item.returnReason %>
                            </p>
                          </div>
                        </div>

                        <div class="flex gap-2 pt-1">
                          <form class="flex-1" method="POST"
                            action="/admin/orders/returns/approve/<%= r.orderId %>/<%= r.item._id %>"
                            onsubmit="return confirmApprove(event)">
                            <button
                              class="w-full flex justify-center items-center gap-1 px-3 py-2 bg-green-600 hover:bg-green-700 text-white rounded text-sm transition">
                              <i class="fas fa-check"></i> Approve
                            </button>
                          </form>
                          <form class="flex-1" method="POST"
                            action="/admin/orders/returns/reject/<%= r.orderId %>/<%= r.item._id %>"
                            onsubmit="return confirmCancel(event)">
                            <button
                              class="w-full flex justify-center items-center gap-1 px-3 py-2 bg-red-600 hover:bg-red-700 text-white rounded text-sm transition">
                              <i class="fas fa-xmark"></i> Reject
                            </button>
                          </form>
                        </div>
                      </div>
                      <% }) %>
                        <% } %>
              </div>
            </div>
          </main>
      </div>
  </div>
  <script>

    function confirmApprove(event) {
      event.preventDefault(); // stop form submit

      const form = event.target;

      Swal.fire({
        title: 'Approve Return?',
        text: 'This action will approve the return request.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#16a34a', // green
        cancelButtonColor: '#dc2626', // red
        confirmButtonText: 'Yes, approve',
        cancelButtonText: 'Cancel'
      }).then((result) => {
        if (result.isConfirmed) {
          form.submit(); // submit ONLY after confirmation
        }
      });

      return false;
    }

    function confirmCancel(event) {
      event.preventDefault(); // stop form submit

      const form = event.target;

      Swal.fire({
        title: 'Cancel Return?',
        text: 'This action will Cancel the return request.',
        icon: 'warning',
        confirmButtonColor: '#dc2626',
        confirmButtonText: 'Yes, Cancel',
      }).then((result) => {
        if (result.isConfirmed) {
          form.submit(); // submit ONLY after confirmation
        }
      });

      return false;
    }

  </script>

</body>

</html>