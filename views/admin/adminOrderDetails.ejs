<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Details | Mambraville Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="bg-gray-100">
  <div class="flex h-screen">

    <!-- Sidebar -->
    <!-- Mobile Sidebar Toggle -->

    <!-- Sidebar -->
    <%- include('../partials/admin/sidebar') %>

      <!-- Main Content -->
      <div class="flex-1 flex flex-col overflow-hidden">

        <!-- Header -->
        <!-- Header -->
        <%- include('../partials/admin/header', { pageTitle: 'Order Details' }) %>

          <!-- Main Content -->
          <!-- Main Content -->
          <main class="flex-1 overflow-y-auto p-4 md:p-6 bg-white m-2 md:m-4 rounded-lg shadow">

            <h2 class="text-2xl font-bold mb-4">Order Details: <%= order.orderId %>
            </h2>

            <!-- User Info -->
            <div class="mb-4 space-y-1">
              <p><strong>User:</strong>
                <%= order.userId.fullname %> | <%= order.userId.email %>
              </p>
              <p><strong>Status:</strong> <span class="font-semibold text-purple-700">
                  <%= order.status %>
                </span></p>
              <p><strong>Payment Method:</strong> <span class="font-semibold text-purple-700">
                  <%= order.paymentMethod %>
                </span> </p>
              <p><strong>Ordered At:</strong>
                <%= new Date(order.orderedAt).toLocaleString() %>
              </p>
              <% if(order.deliveredAt) { %>
                <p><strong>Delivered At:</strong>
                  <%= new Date(order.deliveredAt).toLocaleString() %>
                </p>
                <% } %>
            </div>

            <!-- Items Table / Cards -->
            <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden mb-4">
              <!-- Desktop Table -->
              <div class="hidden md:block overflow-x-auto">
                <table class="min-w-full">
                  <thead class="bg-gray-100">
                    <tr>
                      <th class="p-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
                      <th class="p-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Image</th>
                      <th class="p-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Qty</th>
                      <th class="p-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Price</th>
                      <th class="p-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                      <th class="p-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-200">
                    <% order.items.forEach(item=> { %>
                      <tr class="hover:bg-gray-50">
                        <td class="p-3 whitespace-nowrap text-sm text-gray-900">
                          <%= item.name %>
                        </td>
                        <td class="p-3 whitespace-nowrap">
                          <% if(item.productId && item.productId.productImages && item.productId.productImages.length>
                            0) { %>
                            <img src="/uploads/product-images/<%= item.productId.productImages[0] %>"
                              alt="<%= item.name %>" class="w-12 h-12 object-cover rounded border">
                            <% } else if (item.image) { %>
                              <img src="<%= item.image %>" alt="<%= item.name %>"
                                class="w-12 h-12 object-cover rounded border">
                              <% } else { %>
                                <div
                                  class="w-12 h-12 bg-gray-200 rounded flex items-center justify-center text-gray-400">
                                  <i class="fas fa-image"></i>
                                </div>
                                <% } %>
                        </td>
                        <td class="p-3 whitespace-nowrap text-sm text-gray-600">
                          <%= item.qty %>
                        </td>
                        <td class="p-3 whitespace-nowrap text-sm text-gray-900 font-medium">₹<%= item.finalPrice %>
                        </td>
                        <td class="p-3 whitespace-nowrap text-sm font-semibold">
                          <% if(item.status==='Delivered' ) { %>
                            <span class="text-green-600">
                              <%= item.status %>
                            </span>
                            <% } else if(item.status==='Cancelled' ) { %>
                              <span class="text-red-600">
                                <%= item.status %>
                              </span>
                              <% } else if(item.status==='Returned' ) { %>
                                <span class="text-orange-600">
                                  <%= item.status %>
                                </span>
                                <% } else { %>
                                  <span class="text-purple-700">
                                    <%= item.status %>
                                  </span>
                                  <% } %>
                        </td>
                        <td class="p-3 whitespace-nowrap text-sm">
                          <% if(item.status !=="Cancelled" ) { %>
                            <form action="/admin/order/cancel-item/<%= order._id %>/<%= item._id %>" method="POST">
                              <button type="submit"
                                class="px-3 py-1 bg-red-600 hover:bg-red-700 text-white rounded transition text-xs">Cancel</button>
                            </form>
                            <% } else { %>
                              <span class="text-gray-400 italic">Cancelled</span>
                              <% } %>
                        </td>
                      </tr>
                      <% }) %>
                  </tbody>
                </table>
              </div>

              <!-- Mobile Cards -->
              <div class="md:hidden grid grid-cols-1 divide-y divide-gray-200">
                <% order.items.forEach(item=> { %>
                  <div class="p-4 space-y-3">
                    <div class="flex justify-between items-start">
                      <div class="flex items-center space-x-3">
                        <% if(item.productId && item.productId.productImages && item.productId.productImages.length> 0)
                          { %>
                          <img src="/uploads/product-images/<%= item.productId.productImages[0] %>"
                            alt="<%= item.name %>" class="w-12 h-12 object-cover rounded border">
                          <% } else if (item.image) { %>
                            <img src="<%= item.image %>" alt="<%= item.name %>"
                              class="w-12 h-12 object-cover rounded border">
                            <% } else { %>
                              <div class="w-12 h-12 bg-gray-200 rounded flex items-center justify-center text-gray-400">
                                <i class="fas fa-image"></i>
                              </div>
                              <% } %>
                                <h3 class="text-sm font-bold text-gray-900">
                                  <%= item.name %>
                                </h3>
                      </div>
                      <% if(item.status==='Delivered' ) { %>
                        <span class="text-xs font-semibold text-green-600 bg-green-100 px-2 py-1 rounded">
                          <%= item.status %>
                        </span>
                        <% } else if(item.status==='Cancelled' ) { %>
                          <span class="text-xs font-semibold text-red-600 bg-red-100 px-2 py-1 rounded">
                            <%= item.status %>
                          </span>
                          <% } else if(item.status==='Returned' ) { %>
                            <span class="text-xs font-semibold text-orange-600 bg-orange-100 px-2 py-1 rounded">
                              <%= item.status %>
                            </span>
                            <% } else { %>
                              <span class="text-xs font-semibold text-purple-700 bg-purple-100 px-2 py-1 rounded">
                                <%= item.status %>
                              </span>
                              <% } %>
                    </div>
                    <div class="flex justify-between items-center text-sm">
                      <div class="text-gray-500">Qty: <span class="text-gray-900 font-medium">
                          <%= item.qty %>
                        </span></div>
                      <div class="font-bold text-gray-900">₹<%= item.finalPrice %>
                      </div>
                    </div>
                    <% if(item.status !=="Cancelled" ) { %>
                      <div class="pt-2">
                        <form action="/admin/order/cancel-item/<%= order._id %>/<%= item._id %>" method="POST">
                          <button type="submit"
                            class="w-full px-3 py-2 bg-red-600 hover:bg-red-700 text-white rounded transition text-sm font-medium">Cancel
                            Item</button>
                        </form>
                      </div>
                      <% } %>
                  </div>
                  <% }) %>
              </div>
            </div>

            <p class="font-bold mb-4">Total Amount: ₹<%= order.totalAmount %>
            </p>

            <!-- Cancel Entire Order (optional) -->
            <% if(order.status !=="Cancelled" ) { %>
              <form action="/admin/orders/<%= order._id %>/cancel" method="POST">
                <button type="submit" class="px-4 py-2 bg-red-600 text-white rounded">
                  Cancel Entire Order
                </button>
              </form>

              <% } %>

                <!-- Update Order Status -->
                <form action="/admin/order/status/<%= order._id %>" method="POST" class="mb-4 flex items-center gap-2">
                  <select name="status" class="border p-2 rounded">
                    <option value="Pending" <%=order.status==='Pending' ? 'selected' : '' %>>Pending</option>
                    <option value="Shipped" <%=order.status==='Shipped' ? 'selected' : '' %>>Shipped</option>
                    <option value="Out for Delivery" <%=order.status==='Out for Delivery' ? 'selected' : '' %>>Out for
                      Delivery</option>
                    <option value="Delivered" <%=order.status==='Delivered' ? 'selected' : '' %>>Delivered</option>
                    <option value="Returned" <%=order.status==='Returned' ? 'selected' : '' %>>Returned</option>
                    <option value="Cancelled" <%=order.status==='Cancelled' ? 'selected' : '' %>>Cancelled</option>
                  </select>
                  <button type="submit" class="px-4 py-2 bg-purple-700 text-white rounded">Update Status</button>
                </form>

          </main>
      </div>
  </div>

  <script>
  </script>
</body>

</html>