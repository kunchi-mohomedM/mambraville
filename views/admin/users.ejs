<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management | Mambraville Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.16.1/sweetalert2.min.js"
        integrity="sha512-LGHBR+kJ5jZSIzhhdfytPoEHzgaYuTRifq9g5l6ja6/k9NAOsAi5dQh4zQF6JIRB8cAYxTRedERUF+97/KuivQ=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/sweetalert2/11.16.1/sweetalert2.css"
        integrity="sha512-fjO3Vy3QodX9c6G9AUmr6WuIaEPdGRxBjD7gjatG5gGylzYyrEq3U0q+smkG6CwIY0L8XALRFHh4KPHig0Q1ug=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        /* Custom styles removed - using Tailwind classes */
    </style>
</head>

<body class="bg-gray-100 min-h-screen">
    <div class="flex h-screen">
        <!-- Mobile Sidebar Toggle -->

        <!-- Sidebar -->
        <%- include('../partials/admin/sidebar') %>

            <!-- Main Content -->
            <div class="flex-1 flex flex-col overflow-hidden">
                <!-- Header -->
                <%- include('../partials/admin/header', { pageTitle: 'User Management' }) %>

                    <!-- Content -->
                    <main class="flex-1 p-6 overflow-y-auto">
                        <div class="max-w-7xl mx-auto bg-white rounded-lg shadow">
                            <div class="p-6">
                                <div
                                    class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
                                    <!-- Search Form -->
                                    <form action="/admin/users" method="GET" class="flex items-center gap-4">
                                        <div class="relative w-full sm:w-64">
                                            <input type="text" id="userSearchInput" name="search"
                                                placeholder="Search for user"
                                                value="<%= typeof search !== 'undefined' ? search : '' %>" class="w-full bg-white bg-opacity-20 rounded-full py-2 px-4 pl-10 pr-10 text-gray-700 placeholder-gray-400 
    focus:outline-none focus:ring-2 focus:ring-blue-400" />

                                            <!-- Search icon -->
                                            <i
                                                class="fas fa-search absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400"></i>

                                            <!-- Clear button -->
                                            <button type="button" id="clearUserSearchBtn"
                                                class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-black hidden">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </div>

                                        <button type="submit"
                                            class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">Search</button>
                                    </form>

                                    <!-- Sort Dropdown -->
                                    <form action="/admin/users" method="GET">
                                        <label for="sort" class="block text-gray-700 font-medium mb-2">Sort By:</label>
                                        <select id="sort" name="sort" onchange="this.form.submit()" class="w-full sm:w-52 px-4 py-2 text-gray-700 bg-white border border-gray-300 rounded-lg shadow-sm 
                                    focus:outline-none focus:ring-2 focus:ring-blue-400">
                                            <option value="asc" <%=sort==='asc' ? 'selected' : '' %>>A to Z</option>
                                            <option value="desc" <%=sort==='desc' ? 'selected' : '' %>>Z to A</option>
                                            <option value="active" <%=sort==='active' ? 'selected' : '' %>>Active Users
                                            </option>
                                            <option value="blocked" <%=sort==='blocked' ? 'selected' : '' %>>Blocked
                                                Users
                                            </option>
                                        </select>
                                        <input type="hidden" name="page" value="1">
                                        <input type="hidden" name="search" value="<%= search %>">
                                    </form>
                                </div>

                                <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
                                    <!-- Desktop Table -->
                                    <div class="hidden md:block overflow-x-auto">
                                        <table class="min-w-full divide-y divide-gray-200">
                                            <thead class="bg-gray-50">
                                                <tr>
                                                    <th
                                                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                        Profile</th>
                                                    <th
                                                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                        Username</th>
                                                    <th
                                                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                        Email</th>
                                                    <th
                                                        class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                        Action</th>
                                                </tr>
                                            </thead>
                                            <tbody class="bg-white divide-y divide-gray-200">
                                                <% if(users && users.length> 0) { %>
                                                    <% users.forEach(user=> { %>
                                                        <tr class="hover:bg-gray-50 transition">
                                                            <td class="px-6 py-4 whitespace-nowrap">
                                                                <div
                                                                    class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center text-purple-700 font-bold">
                                                                    <%= user.fullname.charAt(0).toUpperCase() %>
                                                                </div>
                                                            </td>
                                                            <td
                                                                class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 font-medium">
                                                                <%= user.fullname %>
                                                            </td>
                                                            <td
                                                                class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                                                <%= user.email %>
                                                            </td>
                                                            <td class="px-6 py-4 whitespace-nowrap">
                                                                <button
                                                                    class="btn-block text-white px-4 py-1.5 rounded text-xs font-medium uppercase tracking-wide transition-colors <%= user.isBlocked ? 'bg-red-600 hover:bg-red-700' : 'bg-green-600 hover:bg-green-700' %>"
                                                                    data-user-id="<%= user._id %>">
                                                                    <%= user.isBlocked ? 'Unblock' : 'Block' %>
                                                                </button>
                                                            </td>
                                                        </tr>
                                                        <% }) %>
                                                            <% } else { %>
                                                                <tr>
                                                                    <td colspan="4"
                                                                        class="px-6 py-10 text-center text-gray-500">No
                                                                        Users Found</td>
                                                                </tr>
                                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>

                                    <!-- Mobile Cards -->
                                    <div class="md:hidden grid grid-cols-1 divide-y divide-gray-200">
                                        <% if(users && users.length> 0) { %>
                                            <% users.forEach(user=> { %>
                                                <div
                                                    class="p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                                                    <div class="flex items-center space-x-3">
                                                        <div
                                                            class="w-10 h-10 rounded-full bg-purple-100 flex-shrink-0 flex items-center justify-center text-purple-700 font-bold">
                                                            <%= user.fullname.charAt(0).toUpperCase() %>
                                                        </div>
                                                        <div class="min-w-0 flex-1">
                                                            <p class="text-sm font-medium text-gray-900 truncate">
                                                                <%= user.fullname %>
                                                            </p>
                                                            <p class="text-xs text-gray-500 truncate">
                                                                <%= user.email %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                    <div class="flex justify-end">
                                                        <button
                                                            class="btn-block text-white px-3 py-1.5 rounded text-xs font-medium uppercase tracking-wide transition-colors <%= user.isBlocked ? 'bg-red-600 hover:bg-red-700' : 'bg-green-600 hover:bg-green-700' %>"
                                                            data-user-id="<%= user._id %>">
                                                            <%= user.isBlocked ? 'Unblock' : 'Block' %>
                                                        </button>
                                                    </div>
                                                </div>
                                                <% }) %>
                                                    <% } else { %>
                                                        <div class="p-8 text-center text-gray-500">No Users Found</div>
                                                        <% } %>
                                    </div>
                                </div>

                                <!-- Pagination -->
                                <% if (totalPages> 1) { %>
                                    <div class="p-6 flex justify-center">
                                        <nav class="flex items-center gap-1">
                                            <% if (page> 1) { %>
                                                <a href="/admin/users?page=<%= page - 1 %>&search=<%= search %>&sort=<%= sort %>"
                                                    class="px-3 py-1 bg-gray-200 rounded-l-md hover:bg-gray-300">
                                                    <i class="fas fa-chevron-left text-gray-600"></i>
                                                </a>
                                                <% } %>
                                                    <% for(let i=1; i <=totalPages; i++) { %>
                                                        <a href="/admin/users?page=<%= i %>&search=<%= search %>&sort=<%= sort %>"
                                                            class="px-3 py-1 <%= page === i ? 'bg-blue-500 text-white' : 'bg-gray-200 text-gray-600 hover:bg-gray-300' %>">
                                                            <%= i %>
                                                        </a>
                                                        <% } %>
                                                            <% if (page < totalPages) { %>
                                                                <a href="/admin/users?page=<%= page + 1 %>&search=<%= search %>&sort=<%= sort %>"
                                                                    class="px-3 py-1 bg-gray-200 rounded-r-md hover:bg-gray-300">
                                                                    <i class="fas fa-chevron-right text-gray-600"></i>
                                                                </a>
                                                                <% } %>
                                        </nav>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                    </main>
            </div>
    </div>

    <script>


        // 🔍 User search clear button logic
        const userSearchInput = document.getElementById("userSearchInput");
        const clearUserSearchBtn = document.getElementById("clearUserSearchBtn");

        if (userSearchInput && clearUserSearchBtn) {
            // Show clear button if value already exists
            clearUserSearchBtn.classList.toggle("hidden", !userSearchInput.value);

            // Toggle while typing
            userSearchInput.addEventListener("input", () => {
                clearUserSearchBtn.classList.toggle("hidden", !userSearchInput.value);
            });

            // Clear search and reload users page
            clearUserSearchBtn.addEventListener("click", () => {
                window.location.href = "/admin/users";
            });
        }



        document.addEventListener("DOMContentLoaded", () => {
            // Toggle sidebar

            // Block/Unblock functionality (without alerts)
            const blockButtons = document.querySelectorAll('.btn-block');
            blockButtons.forEach(button => {
                button.addEventListener('click', async function () {
                    const userId = this.getAttribute('data-user-id');

                    const result = await Swal.fire({
                        title: "Are you sure?",
                        text: "Do you want to change the block status of this user?",
                        icon: "warning",
                        showCancelButton: true,
                        confirmButtonColor: "#3085d6",
                        cancelButtonColor: "#d33",
                        confirmButtonText: "Yes, change it!"
                    });
                    if (result.isConfirmed) {
                        try {
                            const response = await fetch(`/admin/users/block/${userId}`, {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' }
                            });
                            const data = await response.json();
                            if (data.success) {
                                this.textContent = data.isBlocked ? 'Unblock' : 'Block';
                                this.classList.toggle('bg-blue-500');
                                this.classList.toggle('bg-red-500');
                                this.classList.toggle('hover:bg-blue-600');
                                this.classList.toggle('hover:bg-red-600');
                            } else {
                                console.error(data.message);
                            }
                        } catch (error) {
                            console.error('Error:', error);
                        }
                    }
                });
            });

            // Modal functionality
            const addUserBtn = document.getElementById('add-user');
            const modal = document.getElementById('add-user-modal');
            const closeModal = document.getElementById('close-modal');
            const cancelModal = document.getElementById('cancel-modal');
            const addUserForm = document.getElementById('add-user-form');

            function toggleModal() {
                modal.classList.toggle('hidden');
            }

            addUserBtn.addEventListener('click', toggleModal);
            closeModal.addEventListener('click', toggleModal);
            cancelModal.addEventListener('click', toggleModal);
            overlay.addEventListener('click', toggleModal);

            addUserForm.addEventListener('submit', async function (e) {
                e.preventDefault();
                const formData = new FormData(this);
                try {
                    const response = await fetch('/admin/users/add', {
                        method: 'POST',
                        body: JSON.stringify(Object.fromEntries(formData)),
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const data = await response.json();
                    if (data.success) {
                        toggleModal();
                        location.reload();
                    } else {
                        alert(data.message);
                    }
                } catch (error) {
                    console.error('Error:', error);
                    alert('An error occurred');
                }
            });
        });
    </script>
</body>

</html>