<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Management | Mambraville Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-100 font-sans">
    <div class="flex h-screen">
        <!-- Sidebar (Hidden on mobile, toggleable) -->
        <!-- Mobile Sidebar Toggle -->

        <!-- Sidebar -->
        <%- include('../partials/admin/sidebar') %>

            <!-- Main Content -->
            <div class="flex-1 flex flex-col overflow-hidden">
                <!-- Header with Mobile Menu Toggle -->
                <!-- Header -->
                <!-- Header -->
                <%- include('../partials/admin/header', { pageTitle: 'Category' }) %>

                    <!-- Content -->
                    <main class="flex-1 overflow-y-auto p-4 md:p-6 bg-white m-2 md:m-4 rounded-lg shadow">
                        <div class="overflow-x-auto">
                            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-6">
                                <div>
                                    <h2 class="text-xl font-semibold text-gray-800">Category List</h2>
                                    <p class="text-gray-500 mt-1">Manage product categories</p>
                                </div>
                                <a href="addCategory"
                                    class="mt-4 sm:mt-0 bg-purple-600 text-white px-4 py-2.5 rounded-lg hover:bg-purple-700 flex items-center transition shadow-sm">
                                    <i class="fas fa-plus mr-2"></i>Add New Category
                                </a>
                            </div>

                            <!-- Responsive Table/Card Layout -->
                            <div class="bg-white rounded-xl shadow border border-gray-200 overflow-hidden">
                                <% if(categories.length> 0) { %>
                                    <!-- Desktop Table (Hidden on Mobile) -->
                                    <div class="hidden md:block overflow-x-auto">
                                        <table class="min-w-full divide-y divide-gray-200">
                                            <thead class="bg-gray-50">
                                                <tr>
                                                    <th
                                                        class="px-6 py-3.5 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                                                        Category Name</th>
                                                    <th
                                                        class="px-6 py-3.5 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                                                        Description</th>
                                                    <th
                                                        class="px-6 py-3.5 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                                                        Action</th>
                                                </tr>
                                            </thead>
                                            <tbody class="bg-white divide-y divide-gray-200">
                                                <% categories.forEach(category=> { %>
                                                    <tr class="hover:bg-gray-50 transition">
                                                        <td class="px-6 py-4 text-sm font-medium text-gray-900">
                                                            <%= category.categoryname %>
                                                        </td>
                                                        <td class="px-6 py-4 text-sm text-gray-700">
                                                            <%= category.description %>
                                                        </td>
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                                            <div class="flex space-x-3">
                                                                <a href="/admin/editCategory/<%= category._id %>"
                                                                    class="text-blue-600 hover:text-blue-900 bg-blue-50 p-2 rounded-lg transition">
                                                                    <i class="fas fa-edit"></i>
                                                                </a>
                                                                <button onclick="deleteCategory('<%= category._id %>')"
                                                                    class="text-red-600 hover:text-red-900 bg-red-50 p-2 rounded-lg transition">
                                                                    <i class="fas fa-trash"></i>
                                                                </button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% }) %>
                                            </tbody>
                                        </table>
                                    </div>

                                    <!-- Mobile Card Layout (Visible on Mobile) -->
                                    <div class="md:hidden">
                                        <div class="grid grid-cols-1 divide-y divide-gray-100">
                                            <% categories.forEach(category=> { %>
                                                <div class="p-4 space-y-3">
                                                    <div class="flex justify-between items-start">
                                                        <h3 class="text-lg font-semibold text-gray-900">
                                                            <%= category.categoryname %>
                                                        </h3>
                                                        <div class="flex space-x-2">
                                                            <a href="/admin/editCategory/<%= category._id %>"
                                                                class="text-blue-600 hover:text-blue-900 bg-blue-50 p-2 rounded-lg">
                                                                <i class="fas fa-edit"></i>
                                                            </a>
                                                            <button onclick="deleteCategory('<%= category._id %>')"
                                                                class="text-red-600 hover:text-red-900 bg-red-50 p-2 rounded-lg">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <span
                                                            class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Description</span>
                                                        <p class="text-sm text-gray-700 mt-1">
                                                            <%= category.description %>
                                                        </p>
                                                    </div>
                                                </div>
                                                <% }) %>
                                        </div>
                                    </div>
                                    <% } else { %>
                                        <div class="p-6 text-center text-gray-500">
                                            No category found
                                        </div>
                                        <% } %>
                            </div>
                        </div>

                        <!-- Pagination -->
                        <!-- Pagination -->
                        <% if (typeof totalPages !=='undefined' && totalPages> 1) { %>
                            <div class="flex justify-center mt-4 md:mt-6">
                                <nav class="flex items-center space-x-1">
                                    <% if (currentPage> 1) { %>
                                        <a href="?page=<%= currentPage - 1 %>"
                                            class="px-2 py-1 md:px-3 md:py-1 bg-gray-200 rounded-l-md hover:bg-gray-300">
                                            <i class="fas fa-chevron-left text-gray-600"></i>
                                        </a>
                                        <% } %>

                                            <% for(let i=1; i <=totalPages; i++) { %>
                                                <a href="?page=<%= i %>"
                                                    class="px-2 py-1 md:px-3 md:py-1 <%= currentPage === i ? 'bg-purple-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300' %> rounded-md">
                                                    <%= i %>
                                                </a>
                                                <% } %>

                                                    <% if (currentPage < totalPages) { %>
                                                        <a href="?page=<%= currentPage + 1 %>"
                                                            class="px-2 py-1 md:px-3 md:py-1 bg-gray-200 rounded-r-md hover:bg-gray-300">
                                                            <i class="fas fa-chevron-right text-gray-600"></i>
                                                        </a>
                                                        <% } %>
                                </nav>
                            </div>
                            <% } %>
                    </main>
            </div>
    </div>


    <script>
        // Logout (optional confirmation)

        // Delete Category (confirmation + success)
        function deleteCategory(categoryId) {
            Swal.fire({
                title: "Are you sure?",
                text: "This will permanently delete the category!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Yes, delete it"
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `/admin/category/delete/${categoryId}`;
                }
            });
        }

  // Show flash messages
  <% if (success && success.length > 0) { %>
            Swal.fire({
                icon: "success",
                title: "<%= success %>",
                showConfirmButton: false,
                timer: 1800
            });
  <% } %>

  <% if (error && error.length > 0) { %>
            Swal.fire({
                icon: "error",
                title: "Error",
                text: "<%= error %>",
                confirmButtonColor: "#d33"
            });
  <% } %>



    </script>
</body>

</html>