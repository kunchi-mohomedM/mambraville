<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Coupon | Mambraville Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body class="bg-gray-100">

  <div class="flex h-screen">
    <%- include('../partials/admin/sidebar') %>

    <div class="flex-1 flex flex-col overflow-hidden">
      <%- include('../partials/admin/header', { pageTitle: 'Edit Coupon' }) %>

      <main class="flex-1 overflow-y-auto p-4 md:p-6 bg-white m-2 md:m-4 rounded-lg shadow">
        <div class="max-w-2xl mx-auto">
          <h2 class="text-2xl font-bold mb-6 text-purple-900">Edit Coupon</h2>

          <form id="couponForm" class="space-y-6">
            <input type="hidden" name="couponId" value="<%= coupon._id %>">

            <!-- Coupon Code -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Coupon Code *</label>
              <input type="text" id="coupon-code" name="code" required
                     value="<%= coupon.code %>" maxlength="10"
                     class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-600" />
              <p id="code-error" class="text-red-600 text-sm mt-1 hidden"></p>
            </div>

            <!-- Discount Type -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Discount Type *</label>
              <select id="discount-type" name="discountType" required
                      class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-600">
                <option value="percentage" <%= coupon.discountType === 'percentage' ? 'selected' : '' %>>Percentage</option>
                <option value="fixed"      <%= coupon.discountType === 'fixed'      ? 'selected' : '' %>>Fixed Amount</option>
              </select>
            </div>

            <!-- Discount Value -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Discount Value *</label>
              <input type="number" id="discount" name="discountValue" required min="1" step="0.01"
                     value="<%= coupon.discountValue %>"
                     class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-600" />
              <p id="discount-error" class="text-red-600 text-sm mt-1 hidden"></p>
            </div>

            <!-- Minimum Purchase -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Minimum Purchase Amount</label>
              <input type="number" id="min-purchase" name="minPurchase" min="0" step="0.01"
                     value="<%= coupon.minPurchase %>"
                     class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-600"
                     placeholder="0 = no minimum" />
              <p id="minpurchase-error" class="text-red-600 text-sm mt-1 hidden"></p>
            </div>

            <!-- Max Discount (only for percentage) -->
            <div id="max-discount-field" class="<%= coupon.discountType === 'fixed' ? 'hidden' : '' %>">
              <label class="block text-sm font-medium text-gray-700 mb-1">Maximum Discount Amount</label>
              <input type="number" id="max-discount" name="maxDiscount" min="0" step="0.01"
                     value="<%= coupon.maxDiscount %>"
                     class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-600" />
              <p id="maxdiscount-error" class="text-red-600 text-sm mt-1 hidden"></p>
            </div>

            <!-- Start Date -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Start Date *</label>
              <input type="date" name="startdate" required
                     value="<%= coupon.startDate %>"
                     class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-600" />
            </div>

            <!-- Expiry Date -->
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Expiry Date *</label>
              <input type="date" id="expire-date" name="expiryDate" required
                     value="<%= coupon.expiryDate %>"
                     class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-purple-600" />
              <p id="expiry-error" class="text-red-600 text-sm mt-1 hidden"></p>
            </div>

            <div class="flex justify-end pt-4">
              <button type="submit"
                      class="bg-purple-900 hover:bg-purple-800 text-white px-8 py-3 rounded-md font-medium focus:outline-none focus:ring-2 focus:ring-purple-600 focus:ring-offset-2">
                Update Coupon
              </button>
            </div>
          </form>
        </div>
      </main>
    </div>
  </div>

  <script>
    const discountTypeSelect = document.getElementById("discount-type");
    const maxDiscountField = document.getElementById("max-discount-field");

    function toggleMaxDiscountField() {
      if (discountTypeSelect.value === "fixed") {
        maxDiscountField.classList.add("hidden");
        document.getElementById("max-discount").value = "";
        document.getElementById("maxdiscount-error").classList.add("hidden");
      } else {
        maxDiscountField.classList.remove("hidden");
      }
    }

    discountTypeSelect.addEventListener("change", toggleMaxDiscountField);
    toggleMaxDiscountField(); // initial state

    // ── Form submission + validation ───────────────────────────────────────
    document.getElementById("couponForm").addEventListener("submit", async function(e) {
      e.preventDefault();

      document.querySelectorAll('[id$="-error"]').forEach(el => el.classList.add("hidden"));

      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);

      let hasError = false;

      if (!data.code?.trim()) {
        document.getElementById("code-error").textContent = "Coupon code is required";
        document.getElementById("code-error").classList.remove("hidden");
        hasError = true;
      }

      if (!data.discountValue || Number(data.discountValue) <= 0) {
        document.getElementById("discount-error").textContent = "Discount must be greater than 0";
        document.getElementById("discount-error").classList.remove("hidden");
        hasError = true;
      }

      if (!data.startdate || !data.expiryDate) {
        document.getElementById("expiry-error").textContent = "Both start and expiry dates are required";
        document.getElementById("expiry-error").classList.remove("hidden");
        hasError = true;
      }

      // Strict min purchase relation check
      const discType = data.discountType;
      const discVal  = Number(data.discountValue) || 0;
      const minPur   = Number(data.minPurchase)   || 0;
      const maxDisc  = Number(data.maxDiscount)   || 0;

      if (discType === "fixed" && discVal >= minPur && minPur > 0) {
        Swal.fire({
          icon: "error",
          title: "Invalid Discount Rule",
          text: "Fixed discount must be less than minimum purchase amount",
          confirmButtonColor: "#dc2626"
        });
        hasError = true;
      }

      if (discType === "percentage" && maxDisc >= minPur && minPur > 0) {
        Swal.fire({
          icon: "error",
          title: "Invalid Discount Rule",
          text: "Maximum discount must be less than minimum purchase amount",
          confirmButtonColor: "#dc2626"
        });
        hasError = true;
      }

      if (hasError) return;

      try {
        const response = await fetch("/admin/editCoupon", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data)
        });

        const result = await response.json();

        if (response.ok) {
          Swal.fire({
            icon: "success",
            title: "Success",
            text: result.message || "Coupon updated successfully",
            confirmButtonColor: "#6b21a8"
          }).then(() => {
            window.location.href = "/admin/coupon";
          });
        } else {
          Swal.fire({
            icon: "error",
            title: "Error",
            text: result.error || "Failed to update coupon"
          });
        }
      } catch (err) {
        Swal.fire("Error", "Network error - please try again", "error");
      }
    });
  </script>
</body>
</html>