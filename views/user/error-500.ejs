<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>500 Internal Server Error</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex items-center justify-center h-screen p-4">

    <div class="text-center max-w-lg w-full">
        <h1 class="text-9xl font-bold text-red-600">500</h1>
        <p class="text-2xl font-semibold text-gray-800 mt-4">Oops! Something went wrong.</p>
        <p class="text-gray-600 mt-2">We encountered an internal server error. Please try again later or contact support
            if the problem persists.</p>

        <% if (typeof stack !=='undefined' && stack) { %>
            <div class="mt-6 text-left bg-white p-4 rounded-lg shadow border border-gray-200 overflow-x-auto">
                <p class="text-sm font-bold text-red-500 mb-2">Error Details (Dev Mode):</p>
                <pre class="text-xs text-gray-700 whitespace-pre-wrap"><%= stack %></pre>
            </div>
            <% } %>

                <a href="/"
                    class="mt-8 inline-block bg-red-600 text-white px-6 py-3 rounded-lg text-lg font-medium hover:bg-red-700 transition shadow-lg">
                    Go Back Home
                </a>
    </div>

</body>

</html>